# ── Next.js ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ── Google OAuth (NextAuth.js v5) ────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database (PostgreSQL + pgvector) ─────────────────────
# Docker Compose default (works out of the box):
DATABASE_URL=postgresql://english_learning:dev_password@localhost:5432/english_learning_dev

# ── Redis (BullMQ) ───────────────────────────────────────
# Docker Compose default:
REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 / MinIO (image storage) ────────────────
# For local dev: uses MinIO (S3-compatible). Set CLOUDFLARE_R2_ENDPOINT to MinIO.
# For production: use your R2 credentials from Cloudflare dashboard.
CLOUDFLARE_R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=minioadmin
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin123
R2_BUCKET_NAME=english-learning-dev

# ── AI / LLM ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Image APIs ───────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Development flags ────────────────────────────────────
# Set to "true" to bypass Google OAuth in local dev (redirects straight to app)
DEV_BYPASS_AUTH=false
# Set to "true" to return mock data from all AI generators (no real API calls)
AI_MOCK_MODE=false
